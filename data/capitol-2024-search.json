{"help": "https://data.capitol.texas.gov/api/3/action/help_show?name=package_search", "success": true, "result": {"count": 138, "sort": "title_string desc", "facets": {}, "results": [{"license_title": "Creative Commons Attribution", "maintainer": "", "relationships_as_object": [], "private": false, "maintainer_email": "", "num_tags": 0, "id": "4d8298d0-d176-4c19-b174-42837027b73e", "metadata_created": "2019-12-09T20:43:07.787407", "metadata_modified": "2025-01-29T16:21:24.364418", "author": "", "author_email": "", "state": "active", "version": "", "creator_user_id": "3df418eb-d1d5-49c0-808a-b3c768d3ebe9", "type": "dataset", "resources": [{"mimetype": "application/zip", "cache_url": null, "hash": "", "description": "VTDs_24PG.zip - 2024 Primary & General Elections VTDs Shapefile  \r\n\r\nGIS users can join the election data located at https://data.capitol.texas.gov/topic/elections to the 2024 primary & general elections VTDs shapefile in this directory. Use the 'vtdkey' or 'vtdkeyvalue' fields in the election data files to join to the 'VTDKEY' field in the shapefile.\r\n\r\nGIS users can join the population data located at https://data.capitol.texas.gov/dataset/vtds to the 2024 primary & general election VTDs shapefile in this directory. Use the common field name 'VTDKEY' to join the data.", "name": "VTDs_24PG.zip", "format": "SHP", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/906f47e4-4e39-4156-b1bd-4969be0b2780/download/vtds_24pg.zip", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2024-10-01T14:32:56.376304", "state": "active", "mimetype_inner": null, "last_modified": "2025-01-29T16:17:00.671013", "position": 0, "revision_id": "5d87cfbf-6de1-4d79-a547-c44979241dad", "url_type": "upload", "id": "906f47e4-4e39-4156-b1bd-4969be0b2780", "resource_type": null, "size": 46578782}, {"mimetype": "application/zip", "cache_url": null, "hash": "", "description": "2024 Primary & General Elections VTDs, 2020 Census Population", "name": "VTDs_24PG_Pop.zip", "format": "TXT", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/bf9b54a8-090c-41d0-8f00-e263fc1789c5/download/vtds_24pg_pop.zip", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2024-10-01T14:33:39.672409", "state": "active", "mimetype_inner": null, "last_modified": "2025-01-29T16:17:33.528296", "position": 1, "revision_id": "2cb74be6-8244-4961-9d1b-0a5329da751d", "url_type": "upload", "id": "bf9b54a8-090c-41d0-8f00-e263fc1789c5", "resource_type": null, "size": 325805}, {"mimetype": "application/pdf", "cache_url": null, "hash": "", "description": "2020 County Population with 2024 Primary & General Elections VTDs Subtotals  ", "name": "RED605_County_VTD_24PG_Population.pdf", "format": "PDF", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/996412c6-00be-4bac-81b3-93092f6d999c/download/red605_county_vtd_24p_population.pdf", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2024-10-01T14:34:09.148831", "state": "active", "mimetype_inner": null, "last_modified": "2024-10-01T14:34:09.102433", "position": 2, "revision_id": "c1d14b1f-0c40-4570-9b4f-fb928e76ee96", "url_type": "upload", "id": "996412c6-00be-4bac-81b3-93092f6d999c", "resource_type": null, "size": 6753592}, {"mimetype": "application/vnd.ms-excel", "cache_url": null, "hash": "", "description": "2020 County Population with 2024 Primary & General Elections VTDs Subtotals", "name": "RED605_County_VTD_24PG_Population.xls", "format": "XLS", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/3b79a732-f8a1-4185-9bc0-44336715e9a2/download/red605_county_vtd_24p_population.xls", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2024-10-01T14:34:52.049732", "state": "active", "mimetype_inner": null, "last_modified": "2024-10-01T14:34:52.002791", "position": 3, "revision_id": "f1b9f28e-8c42-4357-9501-701b168d57de", "url_type": "upload", "id": "3b79a732-f8a1-4185-9bc0-44336715e9a2", "resource_type": null, "size": 7241664}, {"mimetype": "application/zip", "cache_url": null, "hash": "", "description": "VTDs_22G.zip - 2022 General Election VTDs Shapefile  \r\n\r\nGIS users can join the election data located at https://data.capitol.texas.gov/topic/elections to the 2022 general election VTDs shapefile in this directory. Use the 'vtdkey' or 'vtdkeyvalue' fields in the election data files to join to the 'VTDKEY' field in the shapefile.\r\n\r\nGIS users can join the population data located at https://data.capitol.texas.gov/dataset/vtds to the 2022 general election VTDs shapefile in this directory. Use the common field name 'VTDKEY' to join the data.", "name": "VTDs_22G.zip", "format": "SHP", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/037e1de6-a862-49de-ae31-ae609e214972/download/vtds_22g.zip", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2023-01-20T22:42:15.775532", "state": "active", "mimetype_inner": null, "last_modified": "2023-01-20T22:42:15.735719", "position": 4, "revision_id": "05075ff0-b15d-4724-bb7f-3f5d97e6bc5a", "url_type": "upload", "id": "037e1de6-a862-49de-ae31-ae609e214972", "resource_type": null, "size": 46517113}, {"mimetype": "application/zip", "cache_url": null, "hash": "", "description": "2022 General Election VTDs, 2020 Census Population", "name": "VTDs_22G_Pop.zip", "format": "TXT", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/c2f5a857-0b16-473b-8237-5268c2e25ac2/download/vtds_22g_pop.zip", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2023-01-20T22:43:09.697108", "state": "active", "mimetype_inner": null, "last_modified": "2023-01-20T22:43:09.65