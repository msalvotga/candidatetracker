source_type": null, "size": 548800}, {"mimetype": "application/zip", "cache_url": null, "hash": "", "description": "2021-2022 School Year Districts Shapefile", "name": "SchoolDistricts_SY2122.zip", "format": "SHP", "url": "https://data.capitol.texas.gov/dataset/f2f1e176-e68a-4d39-af89-37ec7e7962dd/resource/4eb54dfb-45ab-4728-bee0-be8cf3effafb/download/schooldistricts_sy2122.zip", "cache_last_updated": null, "package_id": "f2f1e176-e68a-4d39-af89-37ec7e7962dd", "created": "2022-05-16T18:31:33.826055", "state": "active", "mimetype_inner": null, "last_modified": "2022-05-16T18:31:33.788974", "position": 12, "revision_id": "cc7cb40a-cef9-428f-a8d9-2534fd603a85", "url_type": "upload", "id": "4eb54dfb-45ab-4728-bee0-be8cf3effafb", "resource_type": null, "size": 18412973}, {"mimetype": "application/pdf", "cache_url": null, "hash": "", "description": "2021-2022 School Year Districts Population (2020 Census)", "name": "RED635_SchoolDistrict_Population_SY2122.pdf", "format": "PDF", "url": "https://data.capitol.texas.gov/dataset/f2f1e176-e68a-4d39-af89-37ec7e7962dd/resource/d5937c7c-f987-467a-80fa-0c9a14fd2afa/download/red635_schooldistrict_population_sy2122.pdf", "cache_last_updated": null, "package_id": "f2f1e176-e68a-4d39-af89-37ec7e7962dd", "created": "2022-05-16T18:32:28.038912", "state": "active", "mimetype_inner": null, "last_modified": "2022-05-16T18:32:27.999745", "position": 13, "revision_id": "cc7cb40a-cef9-428f-a8d9-2534fd603a85", "url_type": "upload", "id": "d5937c7c-f987-467a-80fa-0c9a14fd2afa", "resource_type": null, "size": 603198}, {"mimetype": "application/vnd.ms-excel", "cache_url": null, "hash": "", "description": "2021-2022 School Year Districts Population (2020 Census)", "name": "RED635_SchoolDistrict_Population_SY2122.xls", "format": "XLS", "url": "https://data.capitol.texas.gov/dataset/f2f1e176-e68a-4d39-af89-37ec7e7962dd/resource/450d3e82-674e-4193-a008-e8f2317ac426/download/red635_schooldistrict_population_sy2122.xls", "cache_last_updated": null, "package_id": "f2f1e176-e68a-4d39-af89-37ec7e7962dd", "created": "2022-05-16T18:32:52.336918", "state": "active", "mimetype_inner": null, "last_modified": "2022-05-16T18:32:52.295978", "position": 14, "revision_id": "cc7cb40a-cef9-428f-a8d9-2534fd603a85", "url_type": "upload", "id": "450d3e82-674e-4193-a008-e8f2317ac426", "resource_type": null, "size": 548800}], "num_resources": 15, "tags": [], "groups": [{"display_name": "Geography", "description": "The geographic data used in redistricting includes the census geography used as building blocks for districts, the county election precincts used to collect and report voter and election returns data, and other geographic areas used for reference, such as cities and school districts.", "image_display_url": "https://data.capitol.texas.gov/uploads/group/2021-08-17-231141.506217redticongeography.svg", "title": "Geography", "id": "730a64b5-f70a-463d-ba87-a875cde6482f", "name": "geography"}], "license_id": "cc-by", "relationships_as_subject": [], "organization": {"description": "", "created": "2019-10-04T11:59:14.663107", "title": "Texas Legislative Council", "name": "tlc", "is_organization": true, "state": "active", "image_url": "https://data.capitol.texas.gov/base/images/tlc-logo.png", "revision_id": "ced4f2d5-7e15-4115-8c24-2fd1ebe9274b", "type": "organization", "id": "eb7dd023-f166-4613-92ff-b6b3d5c026c6", "approval_status": "approved"}, "name": "school-districts", "isopen": true, "url": "", "notes": "## 2025-2026 School Year\r\n\r\nCouncil staff collect school district boundary updates from the Texas Education Agency and county central appraisal districts for each school year. The school district shapefile should be used as a reference for determining the boundaries of school districts. The depiction and designation of the school district boundaries do not constitute a determination of jurisdictional authority or rights of ownership or entitlement, and they are not legal land descriptions. Please consult the appropriate county central appraisal district for additional information on school district boundaries. \r\n\r\n_SchoolDistricts_SY2526.zip_ - 2025-2026 school year districts shapefile  \r\nThe school districts shapefile (.shp) is in a compressed file (.zip) format.\r\n\r\n_RED635_SchoolDistrict_Population_SY2526_ - Report of 2020 Census population by 2025-2026 school year districts  \r\nThe RED635 report is provided in PDF and Excel formats. \r\n\r\nNote: The 2025-2026 School Year school districts in the council's geographic file are not the same as the districts in the Census Bureau's 2020 TIGER/Line Shapefile. School district population data published by the Texas Legislative Council using the 2025-2026 School Year school districts will not correspond with the school district population data published by the Census Bureau.", "owner_org": "eb7dd023-f166-4613-92ff-b6b3d5c026c6", "extras": [], "license_url": "http://www.opendefinition.org/licenses/cc-by", "title": "School Districts", "revision_id": "e6d25ed7-fea8-46bf-b4a7-7a00022ea191"}, {"license_title": "Creative Commons Attribution", "maintainer": "", "relationships_as_object": [], "private": false, "maintainer_email": "", "num_tags": 0, "id": "d04c72b9-16c4-4ab2-8c6d-c666d41e04b7", "metadata_created": "2019-12-09T17:19:31.543860", "metadata_modified": "2025-01-29T15:23:46.027675", "author": "", "author_email": "", "state": "active", "version": "", "creator_user_id": "3df418eb-d1d5-49c0-808a-b3c768d3ebe9", "type": "dataset", "resources": [{"mimetype": "application/zip", "cache_url": null, "hash": "", "description": "2024 General Election Voting Precincts Shapefile", "name": "Precincts24G.zip", "format": "SHP", "url": "https://data.capitol.texas.gov/dataset/d04c72b9-16c4-4ab2-8c6d-c666d41e04b7/resource/4572665a-8de5-461d-84b8-79f704b63530/download/precincts24g.zip", "cache_last_updated": null, "package_id": "d04c72b9-16c4-4ab2-8c6d-c666d41e04b7", "created": "2025-01-28T23:28:20.790510", "state": "active", "mimetype_inner": null