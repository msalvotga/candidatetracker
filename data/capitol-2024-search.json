ry. Use the 'vtdkey' or 'vtdkeyvalue' fields in the election data files to join to the 'VTDKEY' field in the shapefile.\r\n\r\nGIS users can join the population data located at https://data.capitol.texas.gov/dataset/vtds to the 2022 primary election VTDs shapefile in this directory. Use the common field name 'VTDKEY' to join the data.", "name": "VTDs_22P.zip", "format": "SHP", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/e29c61e5-08cf-454d-a7d3-c84b20173032/download/vtds_22p.zip", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2022-08-18T17:03:27.216073", "state": "active", "mimetype_inner": null, "last_modified": "2022-08-18T17:03:27.180859", "position": 8, "revision_id": "05075ff0-b15d-4724-bb7f-3f5d97e6bc5a", "url_type": "upload", "id": "e29c61e5-08cf-454d-a7d3-c84b20173032", "resource_type": null, "size": 46368388}, {"mimetype": "text/plain", "cache_url": null, "hash": "", "description": "2022 Primary Election VTDs, 2020 Census Population", "name": "VTDs_22P_Pop.txt", "format": "TXT", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/f8320a59-9590-40fa-a734-1b05aba983af/download/vtds_22p_pop.txt", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2022-08-18T17:06:34.645380", "state": "active", "mimetype_inner": null, "last_modified": "2022-08-18T17:06:34.610227", "position": 9, "revision_id": "05075ff0-b15d-4724-bb7f-3f5d97e6bc5a", "url_type": "upload", "id": "f8320a59-9590-40fa-a734-1b05aba983af", "resource_type": null, "size": 866449}, {"mimetype": "application/pdf", "cache_url": null, "hash": "", "description": "2020 County Population with 22P VTD Subtotals", "name": "RED605_County_VTD_22P_Population.pdf", "format": "PDF", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/9c047863-8145-4fd2-ac62-2315be5fa748/download/red605_county_vtd_22p_population.pdf", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2022-08-18T17:07:11.345340", "state": "active", "mimetype_inner": null, "last_modified": "2022-08-18T17:07:11.308523", "position": 10, "revision_id": "05075ff0-b15d-4724-bb7f-3f5d97e6bc5a", "url_type": "upload", "id": "9c047863-8145-4fd2-ac62-2315be5fa748", "resource_type": null, "size": 6696319}, {"mimetype": "application/vnd.ms-excel", "cache_url": null, "hash": "", "description": "2020 County Population with 22P VTD Subtotals", "name": "RED605_County_VTD_22P_Population.xls", "format": "XLS", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/b28e6191-396c-4bbc-842a-2312deae886a/download/red605_county_vtd_22p_population.xls", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2022-08-18T17:07:47.503566", "state": "active", "mimetype_inner": null, "last_modified": "2022-08-18T17:07:47.462384", "position": 11, "revision_id": "05075ff0-b15d-4724-bb7f-3f5d97e6bc5a", "url_type": "upload", "id": "b28e6191-396c-4bbc-842a-2312deae886a", "resource_type": null, "size": 7184320}, {"mimetype": "application/zip", "cache_url": null, "hash": "", "description": "VTDs20G.zip - 2020 General Election VTDs (2020 Census)\r\n\r\nGIS users can join the archived _2020 General VTD Election Data (2020).zip_ election data located at https://data.capitol.texas.gov/dataset/comprehensive-election-datasets-compressed-format\r\nto the 2020 general election VTDs shapefile in this directory. Use the 'vtdkey' or 'vtdkeyvalue'\r\nfields in the election data files to join to the 'VTDKEY' field in the shapefile.\r\n\r\nGIS users can join the population data located at https://data.capitol.texas.gov/dataset/vtds\r\nto the 2020 general election VTDs shapfile in this directory. Use the common field\r\nname 'VTDKEY' to join the data.", "name": "VTDs20G_2020.zip", "format": "SHP", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/06157b97-40b8-43af-99d5-bd9b5850b15e/download/vtds20g_2020.zip", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2021-03-01T16:20:57.730324", "state": "active", "mimetype_inner": null, "last_modified": "2021-08-10T20:12:19.360800", "position": 12, "revision_id": "05075ff0-b15d-4724-bb7f-3f5d97e6bc5a", "url_type": "upload", "id": "06157b97-40b8-43af-99d5-bd9b5850b15e", "resource_type": null, "size": 46736728}, {"mimetype": "text/plain", "cache_url": null, "hash": "", "description": "2020 General Election VTDs, 2020 Census Population", "name": "VTDs20G_Pop.txt", "format": "TXT", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/cbf21827-a6af-435b-a3d5-49259f9e1177/download/vtds20g_pop.txt", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2021-09-01T00:16:23.835875", "state": "active", "mimetype_inner": null, "last_modified": "2021-09-01T00:16:23.809027", "position": 13, "revision_id": "05075ff0-b15d-4724-bb7f-3f5d97e6bc5a", "url_type": "upload", "id": "cbf21827-a6af-435b-a3d5-49259f9e1177", "resource_type": null, "size": 1433767}, {"mimetype": "application/pdf", "cache_url": null, "hash": "", "description": "2020 County Population with 20G VTD Subtotals", "name": "RED605_County_VTD_20G_Population.pdf", "format": "PDF", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/8a77ec57-1939-4cb6-9759-1c321cb3afe4/download/red605_county_vtd_population.pdf", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2021-09-01T00:18:08.853637", "state": "active", "mimetype_inner": null, "last_modified": "2021-09-01T00:18:08.825437", "position": 14, "revision_id": "05075ff0-b15d-4724-bb7f-3f5d97e6bc5a", "url_type": "upload", "id": "8a77ec57-1939-4cb6-9759-1c321cb3afe4", "resource_type": null, "size": 6374255}, {"mimetype": "application/vnd.ms-excel", "cache_url": null, "hash": "", "description": "2020 County Population with 20G VTD Subtotals", "name": "RED605_County_VTD_20G_Population.xls", "format": "XLS", "url": "https://data.capitol.texas.gov/dataset/4d8298d0-d176-4c19-b174-42837027b73e/resource/4ce2de84-5d7a-469d-a657-115b81ad8da2/download/red605_county_vtd_population.xls", "cache_last_updated": null, "package_id": "4d8298d0-d176-4c19-b174-42837027b73e", "created": "2021-09-01T00:18:40.418764", "state": "active", "mimetype_inner": null, "last_modified": "2021-09-01T00:18:40.388491", "position": 15, "revision_id": "05075ff0-b15d-4724-bb7f-3f5d97e6bc5a", "url_type": "upload", "id": "4ce2de84-5d7a-469d-a657-115b81ad8da2", "resource_type": null, "size": 6832064}], "num_resources": 16, "tags": [], "groups": [{"display_name": "Geography", "description": "The geographic data used in redistricting includes the census geography used as building blocks for districts, the county election precincts used to collect and report voter and election returns data, and other geographic areas used for reference, such as cities and school districts.", "image_display_url": "https://data.capitol.texas.gov/uploads/group/2021-08-17-231141.506217redticongeography.svg", "title": "Geography", "id": "730a64b5-f70a-463d-ba87-a875cde6482f", "name": "geography"}], "license_id": "cc-by", "relationships_as_subject": [], "organization": {"description": "", "created": "2019-10-04T11:59:14.663107", "title": "Texas Legislative Council", "name": "tlc", "is_organization": true, "state": "active", "image_url": "https://data.capitol.texas.gov/base/images/tlc-logo.png", "revision_id": "ced4f2d5-7e15-4115-8c24-2fd1ebe9274b", "type": "organization", "id": "eb7dd023-f166-4613-92ff-b6b3d5c026c6", "approval_status": "approved"}, "name": "vtds", "isopen": true, "url": "", "notes": "## 2024 Primary & General Elections VTDs  \r\n\r\nVoting Tabulation Districts (VTDs), the census geographic equivalent of county\r\nelection precincts, are created for the purpose of relating 2020 Census population\r\ndata to election precinct data. VTDs can differ from actual election precincts\r\nbecause precincts do not always follow census geography. The VTDs currently included in\r\nthe redistricting database closely correspond to the precincts in effect for the\r\n2024 primary and general elections. On the occasion that a precinct is in two noncontiguous pieces,\r\nit is a suffixed VTD in the database. For example, if precinct 0001 had two non-contiguous\r\nareas, the corresponding VTD would be VTD 0001A and VTD 0001B. If an election\r\nprecinct does not match any census geography, it is consolidated with an adjacent\r\nprecinct and given that precinct's corresponding VTD number. There are 9,712 VTDs \r\nin the 2024 primary & general elections VTDs shapefile.\r\n\r\nGIS users can join the council's [_redistricting election datasets_](https://data.capitol.texas.gov/topic/elections)\r\nto the 2024 primary & general elections VTDs shapefile in this directory. Use the common field\r\nname 'VTDKEY' to join the data.\r\n\r\nGIS users can join 2020 Census population data (VTDs_24PG_Pop.zip)\r\nto the 2024 primary & general elections VTDs shapefile in this directory. Use the common field\r\nname 'VTDKEY' to join the data.\r\n\r\n\r\n__The VTDs shapefile (.shp) is in a compressed file (.zip) format:__  \r\nVTDs_24PG.zip - 2024 Primary & General Elections VTDs\r\n\r\n* CNTY (num) - County FIPS Census code\r\n* COLOR (num) - Color assignment for symbology\r\n* VTD (txt) - VTD name (2024 general election)\r\n* CNTYKEY (num) - Unique code used to join to geographic data\r\n* VTDKEY (num) - Unique code used to join to geographic data\r\n* CNTYVTD (txt) - Unique code used to join geographic data (CNTYKEY + VTD)\r\n\r\n__The population data file contains the 2020 Census population by VTD as comma-separated values:__   \r\nVTDs_24PG_Pop.zip (.txt file in compressed format) - 2024 primary & general elections VTD, 2020 Census population\r\n\r\n* CountyFIPS (txt) - County FIPS Census Code\r\n* County (txt) - County name\r\n* CNTY (num) - County FIPS Census Code\r\n* VTD (txt) - VTD name (2024 general election)\r\n* CNTYVTD (txt) - Unique code used to join geographic data (CNTY + VTD)\r\n* VTDKEY (num) - Unique code used to join to geographic data\r\n* total (num) - Total Population\r\n* anglo (num) - Anglo Population\r\n* nanglo (num) - Non-Anglo Population\r\n* asian (num) - Asian Population\r\n* black (num) - Black Population\r\n* hispanic (num) - Hispanic Population\r\n* bh (num) - Black+Hispanic Population\r\n* vap (num) - Voting Age Population\r\n* anglovap (num) - Anglo Voting Age Population\r\n* nanglovap (num) - Non-Anglo Voting Age Population\r\n* asianvap (num) - Asian Voting Age Population\r\n* blackvap (num) - Black Voting Age Population\r\n* hispvap (num) - Hispanic Voting Age Population\r\n* bhvap (num) - Black+Hispanic Voting Age Population  \r\n\r\nPrevious vintages of VTD data from the 2020s are also available for download:  \r\n_VTDs22G.zip_ - 2022 general election VTDs shapefile  \r\n_VTDs22G_Pop.txt_ - 2020 Census population data by 22G VTDs  \r\n_RED605_County_VTD_22G_Population.pdf_ - Report of 2020 Census county population with 22G VTD subtotals  \r\n_RED605_County_VTD_22G_Population.xls_ - Report of 2020 Census county population with 22G VTD subtotals  \r\n\r\n_VTDs22P.zip_ - 2022 primary election VTDs shapefile  \r\n_VTDs22P_Pop.txt_ - 2020 Census population data by 22P VTDs  \r\n_RED605_County_VTD_22P_Population.pdf_ - Report of 2020 Census county population with 22P VTD subtotals  \r\n_RED605_County_VTD_22P_Population.xls_ - Report of 2020 Census county population with 22P VTD subtotals  \r\n  \r\n_VTDs20G_2020.zip_ - 2020 general election VTDs shapefile  \r\n_VTDs20G_Pop.txt_ - 2020 Census population data by 20G VTDs  \r\n_RED605_County_VTD_20G_Population.pdf_ - Report of 2020 Census county population with 20G VTD subtotals  \r\n_RED605_County_VTD_20G_Population.xls_ - Report of 2020 Census county population with 20G VTD subtotals ", "owner_org": "eb7dd023-f166-4613-92ff-b6b3d5c026c6", "extras": [], "license_url": "http://www.opendefinition.org/licenses/cc-by", "title": "VTDs", "revision_id": "6730b6cb-640f-4895-9bfe-adae9fca72c6"}, {"license_title": "Creative Commons Attribution", "maintainer": "", "relationships_as_object": [], "private": false, "maintainer_email": "", "num_tags": 0, "id": "f2f1e176-e68a-4d39-af89-37ec7e7962dd", "metadata_created": "2019-12-09T21:00:23.657230", "metadata_modified": "2026-03-25T13:54:47.698058", "author": "", "author_email": "", "state": "active", "version": "", "creator_user_id": "3df418eb-d1d5-49c0-808a-b3c768d3ebe9", "type": "dataset", "resources": [{"mimetype": "application/zip", "cache_url": null, "hash": "", "description": "2025-2026 School Year Districts Shapefile", "name": "SchoolDistricts_SY2526.zip", "format": "SHP", "url": "https://data.capitol.texas.gov/dataset/f2f1e176-e68a-4d39-af89-37ec7e7962dd/resource/57fb5e91-c849-4a33-aaa4-ea073ca98f8f/download/schooldistricts_sy2526.zip", "cache_last_updated": null, "package_id": "f2f1e176-e68a-4d39-af89-37ec7e7962dd", "created": "2026-03-25T13:51:54.199041", "state": "active", "mimetype_inner": null, "last_modified": "2026-03-25T13:51:54.141664", "position": 0, "revision_id": "cc7cb40a-cef9-428f-a8d9-2534fd603a85", "url_type": "upload", "id": "57fb5e91-c849-4a33-aaa4-ea073ca98f8f", "resource_type": null, "size": 18355437}, {"mimetype": "application/pdf", "cache_url": null, "hash": "", "description": "2025-2026 School Year Districts Population (2020 Census)", "name": "RED635_SchoolDistrict_Population_SY2526.pdf", "format": "PDF", "url": "https://data.capitol.texas.gov/dataset/f2f1e176-e68a-4d39-af89-37ec7e7962dd/resource/54fcfedc-544b-4672-97ab-e5b83a7263b2/download/red635_schooldistrict_population_sy2526.pdf", "cache_last_updated": null, "package_id": "f2f1e176-e68a-4d39-af89-37ec7e7962dd", "created": "2026-03-25T13:52: