{
  "name": "candidate-lookup",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k \"npm run server\" \"vite\"",
    "server": "node server/index.mjs",
    "start": "node server/index.mjs",
    "db:init": "node server/seed-offices.mjs",
    "db:import": "node server/import-leges-xlsx.mjs",
    "db:fetch-ted-meta": "node server/fetch-ted-meta.mjs",
    "db:import-ted": "node server/import-ted-results.mjs",
    "db:seed-congressional-benchmarks": "node server/seed-congressional-benchmarks.mjs",
    "db:seed-senate-benchmarks": "node server/seed-senate-benchmarks.mjs",
    "db:seed-house-benchmarks": "node server/seed-house-benchmarks.mjs",
    "db:migrate-from-sqlite": "node server/migrate-sqlite-to-pg.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  }
}
