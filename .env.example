# Render sets PORT automatically. Optional override for local API-only runs.
# PORT=3850
# CANDIDATE_LOOKUP_PORT=3850

# PostgreSQL connection string (required)
# Use the Candidate Tracker Render Postgres (database: candidates_2fdi).
# This is NOT the same database as Election Night Tracker (electionnight_db in repo root .env).
# DATABASE_URL=postgresql://user:password@host:5432/candidates_2fdi

# Auth — required for bootstrap admin on first deploy
# AUTH_BOOTSTRAP_ADMIN_EMAIL=msalvo@gregabbott.com
# AUTH_BOOTSTRAP_ADMIN_PASSWORD=your-secure-password

# Optional dev bypass (disables login requirement — local only)
# AUTH_DEV_BYPASS=admin

# Office IPs that may browse as guests without signing in (viewer access only)
# AUTH_GUEST_IPS=12.42.214.58,127.0.0.1,::1
